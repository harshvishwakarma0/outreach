# Frontend + API (same Vercel project)
# Keep VITE_API_BASE_URL empty to use same-domain /api routes.
VITE_API_BASE_URL=

# Supabase server-side credentials (set in Vercel project environment variables)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# App auth secret (use 32+ random characters)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Allowed frontend origin for API CORS
FRONTEND_ORIGIN=https://YOUR-APP.vercel.app